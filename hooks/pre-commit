#!/bin/bash
# Pre-commit hook to enrich new movies with IMDb data
#
# When the 'movies' file is staged and contains NEW movie entries,
# this hook fetches IMDb data for just those new movies before committing.
# Existing movies without IMDb data are left untouched.

set -e

MOVIES_FILE="movies.log"
ENRICH_SCRIPT="/home/k1/public/imdb_helper/scripts/enrich_new_movies.py"
ENRICH_ALL_SCRIPT="enrich_all.py"
FIX_RECOMMENDERS="fix_recommenders.py"

# Check if the movies file is staged for commit
if git diff --cached --name-only | grep -q "^${MOVIES_FILE}$"; then

    echo "Movies file staged - checking for new entries to enrich..."

    # Run the enrich script for new movies only
    if python3 "$ENRICH_SCRIPT" -f "$MOVIES_FILE" 2>/dev/null; then
        # Check if the movies file was modified by the enrichment
        if git diff --name-only | grep -q "^${MOVIES_FILE}$"; then
            echo "IMDb data added - re-staging movies file..."
            git add "$MOVIES_FILE"
        fi
    else
        echo "Warning: New movie enrichment failed, continuing..."
    fi

    # Auto-add recommender property from subsection names
    if [ -f "$FIX_RECOMMENDERS" ]; then
        echo "Fixing recommender properties..."
        if python3 "$FIX_RECOMMENDERS"; then
            if git diff --name-only | grep -q "^${MOVIES_FILE}$"; then
                echo "Recommenders added - re-staging movies file..."
                git add "$MOVIES_FILE"
            fi
        else
            echo "Warning: Fix recommenders failed, continuing..."
        fi
    fi

    # Backfill: enrich ALL movies missing IMDb data (uses remaining API budget)
    if [ -n "$OMDB_API_KEY" ] && [ -f "$ENRICH_ALL_SCRIPT" ]; then
        echo "Backfilling missing IMDb data..."
        if python3 "$ENRICH_ALL_SCRIPT"; then
            if git diff --name-only | grep -q "^${MOVIES_FILE}$"; then
                echo "Backfill data added - re-staging movies file..."
                git add "$MOVIES_FILE"
            fi
        else
            echo "Warning: Backfill enrichment failed, continuing with commit anyway"
        fi
    fi
fi

# --- Blog post auto-tagging ---
# Auto-tag staged blog posts that lack tags, then re-stage them
BLOG_POSTS=$(git diff --cached --name-only --diff-filter=AM | grep '^blog/[0-9].*\.md$' || true)
if [ -n "$BLOG_POSTS" ]; then
    AUTO_TAG_SCRIPT="blog/scripts/auto_tag.py"
    NEEDS_TAG=""
    for post in $BLOG_POSTS; do
        if [ -f "$post" ]; then
            if ! head -20 "$post" | grep -q '^tags:'; then
                NEEDS_TAG="$NEEDS_TAG $post"
            fi
        fi
    done
    if [ -n "$NEEDS_TAG" ]; then
        echo "Auto-tagging blog posts..."
        if python3 "$AUTO_TAG_SCRIPT" $NEEDS_TAG; then
            # Re-stage the modified files
            for post in $NEEDS_TAG; do
                git add "$post"
            done
            echo "Tags added and re-staged."
        else
            echo "WARNING: Auto-tagging failed. Posts committed without tags."
        fi
    fi
fi

exit 0
