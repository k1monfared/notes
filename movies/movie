def cmd_cleanup(args):
    """Run strip-imdb → normalize-keys → dedupe → route in one buffer."""
    lines = read_lines()

    lines, r1, c1 = stage_strip_imdb(lines)
    print('── strip-imdb ──')
    print(f'STRIPPED  {c1["trailing"] + c1["header"]} lines  ({c1["trailing"]} trailing, {c1["header"]} header)')

    lines, r2, c2 = stage_normalize_keys(lines)
    print('── normalize-keys ──')
    parts = ', '.join(f'{k}={v}' for k, v in sorted(c2.items()))
    print(f'RENAMED   {sum(c2.values())} lines  ({parts or "none"})')

    lines, r3, c3 = stage_dedupe(lines)
    print('── dedupe ──')
    if r3:
        for r in r3:
            print(r)
    print(f'MERGED    {c3["merged"]} groups | CONFLICTS {c3["conflicts"]} | TITLE-ONLY {c3["title_only"]}')

    lines, r4, c4 = stage_route(lines)
    print('── route ──')
    total_moves = c4['x_to_review'] + c4['x_to_categorize'] + c4['skipped']
    print(f'MOVED     {total_moves} entries  '
          f'([x]→To review={c4["x_to_review"]}, '
          f'[x]→to categorize={c4["x_to_categorize"]}, '
          f'[-]→Skipped={c4["skipped"]}, '
          f'recommenders added={c4["recommender_added"]})')

    print('── summary ──')
    total_changes = (c1['trailing'] + c1['header'] + sum(c2.values()) + c3['merged'] + total_moves)
    print(f'TOTAL  {total_changes} changes ({"will write" if args.apply else "dry-run, no write"})')

    if args.apply and total_changes > 0:
        write_lines(lines)
        print(f'wrote {MOVIES_FILE}')
    return 0


