def main():
    parser = argparse.ArgumentParser(prog="movie", description="Manage movies.log")
    sub = parser.add_subparsers(dest="command", required=True)

    # add
    p = sub.add_parser("add", help="Add a movie to To Watch (interactive)")
    p.add_argument("-s", "--section", help="Target category (e.g. 'Festivals')")

    # watched
    p = sub.add_parser("watched", help="Mark a movie as watched")
    p.add_argument("title", help="Movie title")

    # review
    p = sub.add_parser("review", help="Add a review to a movie")
    p.add_argument("title", help="Movie title")
    p.add_argument("text", help="Review text")

    # fetch-imdb
    p = sub.add_parser("fetch-imdb", help="Fetch IMDb info for a movie")
    p.add_argument("title", help="Movie title")

    # server & page
    p = sub.add_parser("server", help="Start local dev server and open in browser")
    p.add_argument("-p", "--port", type=int, default=8787, help="Port (default: 8787)")
    sub.add_parser("page", help="Open the GitHub Pages movies page")

    # push
    sub.add_parser("push", help="Commit and push movies.log changes to GitHub")

    # help
    sub.add_parser("help", help="Show detailed help for all commands")

    # placeholders
    sub.add_parser("list", help="List movies (coming soon)")
    sub.add_parser("move", help="Move a movie between sections (coming soon)")
    p = sub.add_parser("search", help="Search movies (coming soon)")
    p.add_argument("query", nargs="?", default="", help="Search query")

    args = parser.parse_args()
    commands = {
        "add": cmd_add,
        "watched": cmd_watched,
        "review": cmd_review,
        "fetch-imdb": cmd_fetch_imdb,
        "help": cmd_help,
        "server": cmd_server,
        "page": cmd_page,
        "push": cmd_push,
        "list": cmd_list,
        "move": cmd_move,
        "search": cmd_search,
    }
    sys.exit(commands[args.command](args))


if __name__ == "__main__":
    main()
