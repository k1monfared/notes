#!/usr/bin/env python3
"""CLI tool for managing books.log."""

import argparse
import csv
import json
import os
import re
import subprocess
import sys
import urllib.request
from pathlib import Path

BOOKS_FILE = Path(__file__).parent.parent / "books.log"
TODO_RE = re.compile(r"^(\s*)\[([x\-? ]?)\]\s*(.+?)\s*:?\s*$", re.IGNORECASE)


# ── File helpers ──────────────────────────────────────────────────────────────

def read_lines():
    return BOOKS_FILE.read_text(encoding="utf-8").splitlines(keepends=True)


def write_lines(lines):
    BOOKS_FILE.write_text("".join(lines), encoding="utf-8")


def normalize(title):
    """Normalize title for matching: lowercase, strip punctuation/subtitles."""
    t = title.lower().strip().rstrip(":")
    # Remove series info like "(Three Men, #1)"
    t = re.sub(r"\s*\([^)]*#\d+[^)]*\)", "", t)
    # Remove subtitle after colon for matching
    short = t.split(":")[0].strip()
    return t, short


def find_book(lines, title):
    """Find a book line by title (fuzzy). Returns (index, indent, match) or None."""
    full, short = normalize(title)
    for i, line in enumerate(lines):
        m = TODO_RE.match(line.rstrip("\n"))
        if m:
            book_full, book_short = normalize(m.group(3))
            if book_full == full or book_short == short or full == book_short:
                return i, len(m.group(1)), m
    return None


def find_section(lines, section_name):
    """Find a top-level section by name. Returns line index or None."""
    for i, line in enumerate(lines):
        stripped = line.strip()
        if stripped and not stripped.startswith("[") and not stripped.startswith("-"):
            if stripped.rstrip(":").lower() == section_name.lower():
                return i
    return None


def find_insert_after(lines, item_idx, item_indent):
    """Find the index after an item's existing children."""
    idx = item_idx + 1
    while idx < len(lines):
        stripped = lines[idx].rstrip("\n")
        if not stripped.strip():
            idx += 1
            continue
        line_indent = len(stripped) - len(stripped.lstrip())
        if line_indent > item_indent:
            idx += 1
        else:
            break
    return idx


def find_section_end(lines, section_idx):
    """Find the last content line index of a section (before next top-level section)."""
    idx = section_idx + 1
    while idx < len(lines):
        stripped = lines[idx].strip()
        # Next top-level section (non-indented, non-empty, not a checkbox item)
        if stripped and not stripped.startswith("[") and not stripped.startswith("-") and not lines[idx].startswith(" "):
            return idx
        idx += 1
    return idx


def has_property(lines, item_idx, item_indent, prop_name):
    """Check if a book entry already has a given property."""
    idx = item_idx + 1
    while idx < len(lines):
        stripped = lines[idx].rstrip("\n")
        if not stripped.strip():
            idx += 1
            continue
        line_indent = len(stripped) - len(stripped.lstrip())
        if line_indent <= item_indent:
            break
        if re.match(rf"\s*-?\s*{re.escape(prop_name)}\s*:", stripped, re.IGNORECASE):
            return True
        # Also check without leading dash (some entries have "Author: X" without dash)
        if stripped.strip().lower().startswith(prop_name.lower()):
            return True
        idx += 1
    return False


def clean_review(text):
    """Clean Goodreads review HTML."""
    if not text:
        return ""
    # Replace <br/> and <br> with space
    text = re.sub(r"<br\s*/?>", " ", text)
    # Strip remaining HTML tags
    text = re.sub(r"<[^>]+>", "", text)
    # Collapse multiple spaces
    text = re.sub(r"  +", " ", text)
    # Replace "" with " (Goodreads CSV escaping)
    text = text.replace('""', '"')
    return text.strip()


def clean_isbn(raw):
    """Clean ISBN from Goodreads CSV format like =\"0123456789\"."""
    if not raw:
        return ""
    return raw.strip().replace('="', "").replace('"', "").strip()


def goodreads_url(book_id):
    """Build Goodreads URL from book ID."""
    return f"https://www.goodreads.com/book/show/{book_id}"


# ── Import Goodreads ─────────────────────────────────────────────────────────

def find_book_by_url(lines, gr_url):
    """Find a book entry whose children include `- goodreads: <gr_url>`.
    Returns (item_idx, item_indent) or None. More reliable than title fuzz."""
    if not gr_url:
        return None
    target = gr_url.strip().lower()
    for i, line in enumerate(lines):
        m = TODO_RE.match(line.rstrip("\n"))
        if not m:
            continue
        idx, indent = i, len(m.group(1))
        end = find_insert_after(lines, idx, indent)
        for j in range(idx + 1, end):
            cl = lines[j].rstrip("\n").strip()
            if cl.lower().startswith("- goodreads:"):
                val = cl.split(":", 1)[1].strip().lower()
                if val == target:
                    return idx, indent
    return None


def review_lines_for(review_text, deep_pad):
    """Split a possibly multi-line review into one nested bullet per line.
    Empty lines are dropped; pre-existing leading dashes are stripped so we
    don't double them up in the output."""
    parts = []
    for raw in (review_text or "").split("\n"):
        s = raw.strip()
        if not s:
            continue
        # Drop a leading "- " in case the value already came in bulleted form
        if s.startswith("- "):
            s = s[2:].strip()
        parts.append(f"{deep_pad}- {s}\n")
    return parts


def cmd_import_goodreads(args):
    """Import Goodreads CSV export into books.log."""
    csv_path = Path(args.csv).expanduser()
    if not csv_path.exists():
        print(f"File not found: {csv_path}")
        return 1

    apply = bool(getattr(args, "apply", False))
    if not apply:
        print("(dry-run — nothing will be written; pass --apply to commit changes)\n")

    # Parse CSV
    books = []
    with open(csv_path, encoding="utf-8") as f:
        for row in csv.DictReader(f):
            books.append(row)

    print(f"Parsed {len(books)} books from Goodreads CSV")

    lines = read_lines()

    # Categorize
    existing_matched = 0
    new_read = []
    new_toread = []
    field_adds = 0

    for row in books:
        title = (row.get("Title") or "").strip()
        if not title:
            continue
        author = (row.get("Author") or "").strip()
        shelf = (row.get("Exclusive Shelf") or "").strip().lower()
        avg_rating = (row.get("Average Rating") or "").strip()
        my_rating = (row.get("My Rating") or "").strip()
        year = (row.get("Original Publication Year") or "").strip() or (row.get("Year Published") or "").strip()
        pages = (row.get("Number of Pages") or "").strip()
        # ISBN often comes as ="0123456789"; strip CSV escaping
        isbn = clean_isbn(row.get("ISBN13") or "") or clean_isbn(row.get("ISBN") or "")
        date_read = (row.get("Date Read") or "").strip()
        date_added = (row.get("Date Added") or "").strip()
        bookshelves = (row.get("Bookshelves") or "").strip()
        shelves = [
            s.strip() for s in bookshelves.split(",")
            if s.strip() and s.strip().lower() not in ("read", "to-read", "currently-reading", "skipped")
        ]
        book_id = (row.get("Book Id") or "").strip()
        review = clean_review(row.get("My Review") or "")
        gr_url = goodreads_url(book_id) if book_id else ""

        # Match by Goodreads URL first (rock-solid), fall back to title fuzz
        result = find_book_by_url(lines, gr_url)
        if result:
            idx, indent = result
        else:
            tr = find_book(lines, title)
            if tr:
                idx, indent, _m = tr
            else:
                idx = indent = None

        if idx is not None:
            # Existing book — enrich with missing fields
            insert_at = find_insert_after(lines, idx, indent)
            pad = " " * (indent + 4)
            deep_pad = " " * (indent + 8)
            added = []

            def add_prop(key, value):
                nonlocal insert_at
                if not value:
                    return
                if has_property(lines, idx, indent, key):
                    return
                lines.insert(insert_at, f"{pad}- {key}: {value}\n")
                insert_at += 1
                added.append(key)

            add_prop("author", author)
            add_prop("year", year)
            add_prop("goodreads", gr_url)
            add_prop("goodreads rating", avg_rating)
            add_prop("my rating", my_rating if (my_rating and my_rating not in ("0", "0.00")) else "")
            add_prop("pages", pages)
            add_prop("isbn", isbn)
            add_prop("date read", date_read)
            add_prop("date added", date_added)
            if shelves and not has_property(lines, idx, indent, "shelves"):
                lines.insert(insert_at, f"{pad}- shelves: {', '.join(shelves)}\n")
                insert_at += 1
                added.append("shelves")
            if review and not has_property(lines, idx, indent, "review"):
                rl = review_lines_for(review, deep_pad)
                if rl:
                    lines.insert(insert_at, f"{pad}- review:\n")
                    insert_at += 1
                    for k, line in enumerate(rl):
                        lines.insert(insert_at + k, line)
                    insert_at += len(rl)
                    added.append("review")

            if added:
                print(f"  updated: {title} (+{', '.join(added)})")
                field_adds += len(added)
            existing_matched += 1

        elif shelf in ("read", "skipped", "currently-reading"):
            new_read.append({
                "title": title, "author": author, "year": year,
                "goodreads": gr_url, "avg_rating": avg_rating,
                "my_rating": my_rating, "pages": pages, "isbn": isbn,
                "date_read": date_read, "date_added": date_added,
                "shelves": shelves, "review": review, "shelf": shelf,
            })
        elif shelf == "to-read":
            new_toread.append({
                "title": title, "author": author, "year": year,
                "goodreads": gr_url, "avg_rating": avg_rating,
                "shelves": shelves,
            })

    print(f"\nSummary:")
    print(f"  {existing_matched} existing books matched (+{field_adds} new fields filled in)")
    print(f"  {len(new_read)} new read/skipped/in-progress books")
    print(f"  {len(new_toread)} new to-read books")

    # Insert "imported from goodreads" section before "reading list"
    if new_read:
        # If section already exists, append into it; otherwise create it before
        # "reading list".
        existing_sec = find_section(lines, "imported from goodreads")
        if existing_sec is not None:
            insert_at_idx = find_section_end(lines, existing_sec)
            section_header_lines = []
        else:
            reading_list_idx = find_section(lines, "reading list")
            insert_at_idx = reading_list_idx if reading_list_idx is not None else len(lines)
            section_header_lines = ["imported from goodreads\n"]

        body = []
        for b in new_read:
            cb = "[x]" if b["shelf"] == "read" else ("[-]" if b["shelf"] == "skipped" else "[?]")
            body.append(f"    {cb} {b['title']}\n")
            if b["author"]:        body.append(f"        - author: {b['author']}\n")
            if b["year"]:          body.append(f"        - year: {b['year']}\n")
            if b["goodreads"]:     body.append(f"        - goodreads: {b['goodreads']}\n")
            if b["avg_rating"]:    body.append(f"        - goodreads rating: {b['avg_rating']}\n")
            if b["my_rating"] and b["my_rating"] not in ("0", "0.00"):
                body.append(f"        - my rating: {b['my_rating']}\n")
            if b["pages"]:         body.append(f"        - pages: {b['pages']}\n")
            if b["isbn"]:          body.append(f"        - isbn: {b['isbn']}\n")
            if b["date_read"]:     body.append(f"        - date read: {b['date_read']}\n")
            if b["date_added"]:    body.append(f"        - date added: {b['date_added']}\n")
            if b["shelves"]:       body.append(f"        - shelves: {', '.join(b['shelves'])}\n")
            if b["review"]:
                rl = review_lines_for(b["review"], "            ")
                if rl:
                    body.append("        - review:\n")
                    body.extend(rl)

        insert_chunk = section_header_lines + body
        lines[insert_at_idx:insert_at_idx] = insert_chunk

    # Append new to-read books to reading list (or create the section)
    if new_toread:
        reading_list_idx = find_section(lines, "reading list")
        if reading_list_idx is None:
            # Create a "reading list" section at the end
            if lines and not lines[-1].endswith("\n"):
                lines.append("\n")
            lines.append("reading list\n")
            reading_list_idx = len(lines) - 1
        end_idx = find_section_end(lines, reading_list_idx)
        body = []
        for b in new_toread:
            body.append(f"    [] {b['title']}\n")
            if b["author"]:        body.append(f"        - author: {b['author']}\n")
            if b["year"]:          body.append(f"        - year: {b['year']}\n")
            if b["goodreads"]:     body.append(f"        - goodreads: {b['goodreads']}\n")
            if b["avg_rating"]:    body.append(f"        - goodreads rating: {b['avg_rating']}\n")
            if b["shelves"]:       body.append(f"        - shelves: {', '.join(b['shelves'])}\n")
        lines[end_idx:end_idx] = body

    if apply:
        write_lines(lines)
        print(f"\nWrote {BOOKS_FILE}")
    else:
        print(f"\nDry-run only. Re-run with --apply to commit changes.")
    return 0


# ── Enrich ───────────────────────────────────────────────────────────────────

def cmd_enrich(args):
    """Fetch Open Library data for a book and insert into books.log."""
    lines = read_lines()
    result = find_book(lines, args.title)

    if not result:
        print(f"Book '{args.title}' not found in books.log")
        return 1

    idx, indent, m = result
    title = m.group(3).strip()
    print(f"Found: {title} (line {idx + 1})")

    # Try to find ISBN in existing properties
    isbn = None
    prop_idx = idx + 1
    while prop_idx < len(lines):
        stripped = lines[prop_idx].rstrip("\n")
        if not stripped.strip():
            prop_idx += 1
            continue
        line_indent = len(stripped) - len(stripped.lstrip())
        if line_indent <= indent:
            break
        isbn_match = re.match(r"\s*-?\s*isbn\s*:\s*(.+)", stripped, re.IGNORECASE)
        if isbn_match:
            isbn = isbn_match.group(1).strip()
        prop_idx += 1

    # Search Open Library by title if no ISBN
    data = None
    if isbn:
        print(f"Looking up ISBN {isbn}...")
        data = ol_fetch_isbn(isbn)
    if not data:
        print(f"Searching Open Library for '{title}'...")
        data = ol_search(title)

    if not data:
        print("No results found on Open Library")
        return 1

    # Build property lines
    insert_at = find_insert_after(lines, idx, indent)
    pad = " " * (indent + 4)
    new_lines = []

    if data.get("pages") and not has_property(lines, idx, indent, "pages"):
        new_lines.append(f"{pad}- pages: {data['pages']}\n")

    if data.get("subjects") and not has_property(lines, idx, indent, "genres"):
        genres = ", ".join(data["subjects"][:6])
        new_lines.append(f"{pad}- genres: {genres}\n")

    if data.get("description") and not has_property(lines, idx, indent, "description"):
        desc = data["description"][:200]
        new_lines.append(f"{pad}- description: {desc}\n")

    if not new_lines:
        print("No new data to add (all fields already present)")
        return 0

    for line in new_lines:
        print(f"  + {line.strip()}")

    lines[insert_at:insert_at] = new_lines
    write_lines(lines)
    print(f"\n{len(new_lines)} lines added")
    return 0


def ol_fetch_isbn(isbn):
    """Fetch book data from Open Library by ISBN."""
    url = f"https://openlibrary.org/isbn/{isbn}.json"
    try:
        with urllib.request.urlopen(url, timeout=10) as resp:
            data = json.loads(resp.read())
    except Exception:
        return None

    result = {"pages": data.get("number_of_pages")}

    # Fetch work for subjects and description
    works = data.get("works", [])
    if works:
        work_key = works[0].get("key", "")
        if work_key:
            result.update(ol_fetch_work(work_key))

    return result


def ol_fetch_work(work_key):
    """Fetch work details from Open Library."""
    url = f"https://openlibrary.org{work_key}.json"
    try:
        with urllib.request.urlopen(url, timeout=10) as resp:
            data = json.loads(resp.read())
    except Exception:
        return {}

    result = {}
    subjects = data.get("subjects", [])
    if subjects:
        result["subjects"] = subjects[:8]

    desc = data.get("description", "")
    if isinstance(desc, dict):
        desc = desc.get("value", "")
    if desc:
        result["description"] = desc.replace("\n", " ").strip()

    return result


def ol_search(title):
    """Search Open Library and return first match data."""
    import urllib.parse
    params = urllib.parse.urlencode({"title": title, "limit": 1})
    url = f"https://openlibrary.org/search.json?{params}"
    try:
        with urllib.request.urlopen(url, timeout=15) as resp:
            data = json.loads(resp.read())
    except Exception as e:
        print(f"Search failed: {e}")
        return None

    docs = data.get("docs", [])
    if not docs:
        return None

    doc = docs[0]
    result = {}

    if doc.get("number_of_pages_median"):
        result["pages"] = doc["number_of_pages_median"]

    subjects = doc.get("subject", [])
    if subjects:
        result["subjects"] = subjects[:8]

    # Try to get description from work
    work_key = doc.get("key", "")
    if work_key:
        result.update(ol_fetch_work(work_key))

    return result if result else None


# ── Push ─────────────────────────────────────────────────────────────────────

def cmd_push(args):
    """Commit and push books.log changes to GitHub."""
    repo_dir = Path(__file__).parent.parent

    result = subprocess.run(
        ["git", "diff", "--name-only", "books.log"],
        capture_output=True, text=True, cwd=repo_dir,
    )
    staged = subprocess.run(
        ["git", "diff", "--cached", "--name-only", "books.log"],
        capture_output=True, text=True, cwd=repo_dir,
    )

    if not result.stdout.strip() and not staged.stdout.strip():
        print("No changes to books.log")
        return 0

    subprocess.run(["git", "add", "books.log"], cwd=repo_dir, check=True)
    subprocess.run(
        ["git", "commit", "-m", "Update books.log"],
        cwd=repo_dir, check=True,
    )
    print("Pushing to GitHub...")
    subprocess.run(["git", "push"], cwd=repo_dir, check=True)
    print("Done.")
    return 0


# ── Help ─────────────────────────────────────────────────────────────────────

def cmd_help(args):
    print("""book - Manage books.log

Commands:
  import-goodreads CSV   Import a Goodreads CSV export into books.log
                         Merges with existing entries, adds new ones

  enrich TITLE           Fetch Open Library data (genres, pages, description)
                         and insert into books.log

  push                   Commit and push books.log changes to GitHub

  help                   Show this help

Examples:
  book import-goodreads ~/Downloads/goodreads_library_export.csv
  book enrich "Crime and Punishment"
  book push""")
    return 0


# ── CLI ───────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(prog="book", description="Manage books.log")
    sub = parser.add_subparsers(dest="command", required=True)

    p = sub.add_parser("import-goodreads", help="Import Goodreads CSV export")
    p.add_argument("csv", help="Path to goodreads_library_export.csv")
    p.add_argument("--apply", action="store_true", help="Write changes (default: dry-run)")

    p = sub.add_parser("enrich", help="Fetch Open Library data for a book")
    p.add_argument("title", help="Book title")

    sub.add_parser("push", help="Commit and push books.log changes")
    sub.add_parser("help", help="Show detailed help")

    args = parser.parse_args()
    commands = {
        "import-goodreads": cmd_import_goodreads,
        "enrich": cmd_enrich,
        "push": cmd_push,
        "help": cmd_help,
    }
    sys.exit(commands[args.command](args))


if __name__ == "__main__":
    main()
